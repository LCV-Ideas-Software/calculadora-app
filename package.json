  "license": "AGPL-3.0-or-later",
  "author": "Leonardo Cardozo Vargas (lcv-leo)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lcv-leo/calculadora-app.git"
  },
  "homepage": "https://github.com/lcv-leo/calculadora-app#readme",
  "bugs": {
    "url": "https://github.com/lcv-leo/calculadora-app/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
