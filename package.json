    "format": "biome format --write src",
    "lint": "biome check src"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "dompurify": "^3.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.3"
